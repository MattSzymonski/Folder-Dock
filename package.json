{
  "name": "folder-dock",
  "displayName": "Folder Dock",
  "description": "Bookmark folders and files, open them in any window, and preview with Workview",
  "version": "1.0.0",
  "publisher": "MattSzymonski",
  "repository": {
    "type": "git",
    "url": "https://github.com/MattSzymonski/Folder-Dock"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "keywords": [
    "vscode",
    "extension",
    "folder",
    "bookmarks",
    "workview",
    "explorer",
    "context menu"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:folderDockBookmarks"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "folder-dock.openFolderInNewWindow",
        "title": "Open This Folder in New VS Code Window"
      },
      {
        "command": "folder-dock.openFolderInCurrentWindow",
        "title": "Open This Folder in This VS Code Window"
      },
      {
        "command": "folder-dock.addBookmark",
        "title": "Add Bookmark",
        "icon": "$(add)"
      },
      {
        "command": "folder-dock.removeBookmark",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "folder-dock.editBookmark",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "folder-dock.openFile",
        "title": "Open File"
      },
      {
        "command": "folder-dock.openInWorkview",
        "title": "Open in Workview"
      },
      {
        "command": "folder-dock.closeWorkview",
        "title": "Close Workview",
        "icon": "$(close)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "folderDockWorkview",
          "name": "Workview",
          "when": "folderDockWorkviewActive"
        },
        {
          "id": "folderDockBookmarks",
          "name": "Bookmarks"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "folder-dock.openFolderInCurrentWindow",
          "when": "explorerResourceIsFolder",
          "group": "navigation@98"
        },
        {
          "command": "folder-dock.openFolderInNewWindow",
          "when": "explorerResourceIsFolder",
          "group": "navigation@99"
        },
        {
          "command": "folder-dock.openInWorkview",
          "when": "explorerResourceIsFolder",
          "group": "navigation@97"
        }
      ],
      "view/title": [
        {
          "command": "folder-dock.addBookmark",
          "when": "view == folderDockBookmarks",
          "group": "navigation"
        },
        {
          "command": "folder-dock.closeWorkview",
          "when": "view == folderDockWorkview",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "folder-dock.openFolderInCurrentWindow",
          "when": "view == folderDockBookmarks && viewItem == bookmarkFolder",
          "group": "open@1"
        },
        {
          "command": "folder-dock.openFolderInNewWindow",
          "when": "view == folderDockBookmarks && viewItem == bookmarkFolder",
          "group": "open@2"
        },
        {
          "command": "folder-dock.openInWorkview",
          "when": "view == folderDockBookmarks && viewItem == bookmarkFolder",
          "group": "open@3"
        },
        {
          "command": "folder-dock.openFile",
          "when": "view == folderDockBookmarks && viewItem == bookmarkFile",
          "group": "open@1"
        },
        {
          "command": "folder-dock.editBookmark",
          "when": "view == folderDockBookmarks",
          "group": "inline@1"
        },
        {
          "command": "folder-dock.removeBookmark",
          "when": "view == folderDockBookmarks",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Folder Dock",
      "properties": {
        "folder-dock.bookmarksStoragePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the directory where `bookmarks.json` will be stored. Leave empty to use VS Code's default global storage."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  }
}